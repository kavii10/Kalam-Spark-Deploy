# ──────────────────────────────────────────────────────────
# Kalam Spark — Frontend Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit the actual .env file to source control.
# ──────────────────────────────────────────────────────────

# Supabase (Database + Auth)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Google AI (Gemini)
VITE_GEMINI_API_KEY=your_gemini_api_key

# YouTube Data API v3
VITE_YOUTUBE_API_KEY=your_youtube_api_key

# Google Books API
VITE_GOOGLE_BOOKS_API_KEY=your_google_books_api_key

# News APIs
VITE_NYT_API_KEY=your_nyt_api_key
VITE_NEWSDATA_API_KEY=your_newsdata_api_key
VITE_GNEWS_API_KEY=your_gnews_api_key
VITE_CURRENTS_API_KEY=your_currents_api_key

# Backend URL
# LOCAL DEV:  http://localhost:8000
# PRODUCTION: your ngrok public URL, e.g. https://abc123.ngrok-free.app
VITE_BACKEND_URL=http://localhost:8000
